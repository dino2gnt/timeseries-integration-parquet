<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<features name="openmms-plugins-timeseries-parquet-plugin-features" xmlns="http://karaf.apache.org/xmlns/features/v1.4.0">

    <feature name="opennms-timeseries-parquet-plugin" description="OpenNMS :: Plugins :: timeseries-parquet-plugin" version="${project.version}">
        <feature dependency="true">aries-blueprint</feature>
        <feature dependency="true">shell</feature>
        <feature version="${opennms.api.version}" dependency="true">opennms-integration-api</feature>

        <!--
            The plugin is a FAT bundle: the entire third-party stack (parquet x6, hadoop x2,
            aircompressor, re2j) is embedded in the plugin jar via Embed-Dependency (see plugin/pom.xml).

            This is deliberate and required. The `org.apache.parquet` package is split across
            parquet-common, parquet-column and parquet-hadoop; installing those as separate wrapped
            bundles makes OSGi wire that one package to a single exporter, so parquet-column can't see
            parquet-common's Preconditions and the blueprint bean fails with NoClassDefFoundError at
            runtime (karaf:verify passes anyway - it doesn't check class-level completeness of a split
            package). Embedding puts every parquet class on one Bundle-ClassPath and dissolves the split.

            Consequently there are no wrap: bundles and no `wrap` feature dependency here any more -
            everything third-party lives inside the one plugin bundle.
        -->
        <bundle>mvn:org.opennms.plugins.timeseries.parquet/parquet-tss-plugin/${project.version}</bundle>
    </feature>

</features>
