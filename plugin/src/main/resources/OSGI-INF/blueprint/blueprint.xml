
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0" xmlns:ext="http://aries.apache.org/blueprint/xmlns/blueprint-ext/v1.1.0"
           xsi:schemaLocation="
		http://www.osgi.org/xmlns/blueprint/v1.0.0
		http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd
		http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0
		http://aries.apache.org/schemas/blueprint-cm/blueprint-cm-1.1.0.xsd
		http://aries.apache.org/blueprint/xmlns/blueprint-ext/v1.1.0
		http://aries.apache.org/schemas/blueprint-ext/blueprint-ext-1.1.xsd
">

    <!--
        Configuration comes from the ConfigAdmin PID org.opennms.timeseries.parquet (e.g.
        ${karaf.etc}/org.opennms.timeseries.parquet.cfg). Blank defaults leave the built-in
        default in place; an empty baseDir falls back to the rrd.base.dir system property.
        update-strategy="reload" restarts the bean (destroy + init) when the config changes.
    -->
    <cm:property-placeholder persistent-id="org.opennms.timeseries.parquet" update-strategy="reload">
        <cm:default-properties>
            <cm:property name="baseDir" value="" />
            <cm:property name="partition.duration" value="P1D" />
            <cm:property name="retention" value="P365D" />
            <cm:property name="retention.sweep.interval" value="P1D" />
            <cm:property name="compression" value="UNCOMPRESSED" />
            <cm:property name="catalog.pruneOnExpiry" value="true" />
            <cm:property name="flush.maxRows" value="8192" />
            <cm:property name="flush.interval" value="PT60S" />
            <cm:property name="compaction.enabled" value="true" />
            <cm:property name="compaction.interval" value="PT1H" />
        </cm:default-properties>
    </cm:property-placeholder>

    <bean id="timeSeriesStorageParquet"
          class="org.opennms.timeseries.impl.parquet.ParquetStorage"
          init-method="init"
          destroy-method="destroy">
        <property name="baseDir" value="${baseDir}" />
        <property name="partitionDuration" value="${partition.duration}" />
        <property name="retention" value="${retention}" />
        <property name="retentionSweepInterval" value="${retention.sweep.interval}" />
        <property name="compression" value="${compression}" />
        <property name="pruneCatalogOnExpiry" value="${catalog.pruneOnExpiry}" />
        <property name="flushMaxRows" value="${flush.maxRows}" />
        <property name="flushInterval" value="${flush.interval}" />
        <property name="compactionEnabled" value="${compaction.enabled}" />
        <property name="compactionInterval" value="${compaction.interval}" />
    </bean>
    <service ref="timeSeriesStorageParquet" interface="org.opennms.integration.api.v1.timeseries.TimeSeriesStorage">
        <service-properties>
            <entry key="registration.export" value="true" />
        </service-properties>
    </service>
    <!-- Same bean, exposed as ParquetMaintenance so the tss-parquet:* shell commands can drive it. -->
    <service ref="timeSeriesStorageParquet" interface="org.opennms.timeseries.impl.parquet.ParquetMaintenance" />
</blueprint>
